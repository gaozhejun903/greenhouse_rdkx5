<?xml version="1.0"?>
<robot name="lidar_robot" xmlns:xacro="http://ros.org/wiki/xacro">
  <link name="base_link"/>
  <link name="laser"/>

  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
</robot>
